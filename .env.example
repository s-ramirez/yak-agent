YAK_BASE_URL=http://localhost:1234
YAK_MODEL=default
YAK_API_KEY=
YAK_LOG_DIR=.yak/logs
YAK_WEBUI_PORT=8420

OPENAI_API_KEY=

# iMessage via BlueBubbles (ServerURL + Password must be set to enable)
# Set YAK_IMESSAGE_ENABLED=false to force-disable even if creds are present.
# YAK_IMESSAGE_ENABLED=true
# YAK_IMESSAGE_SERVER_URL=http://192.168.1.x:1234
# YAK_IMESSAGE_PASSWORD=your-bluebubbles-password
# YAK_IMESSAGE_WEBHOOK_PORT=8421
# YAK_IMESSAGE_WEBHOOK_PATH=/bluebubbles
# YAK_IMESSAGE_OWNER_HANDLES=+15551234567,you@example.com
# YAK_IMESSAGE_GROUP_TAG=@yak

# Discord (Token must be set to enable)
# Set YAK_DISCORD_ENABLED=false to force-disable even if a token is present.
# YAK_DISCORD_ENABLED=true
# YAK_DISCORD_TOKEN=your-discord-bot-token
# YAK_DISCORD_OWNER_IDS=123456789012345678,234567890123456789
# YAK_DISCORD_GUILD_TAG=@yak
